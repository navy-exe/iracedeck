{
  "name": "iracedeck",
  "version": "1.13.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "keysender"
    ]
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "install:stream-deck": "pnpm --filter \"@iracedeck/iracing-sdk\" --filter \"@iracedeck/stream-deck-*\" install",
    "build:ts": "turbo run build --filter=!@iracedeck/iracing-native --filter=!@iracedeck/website",
    "build:force": "turbo run build --force",
    "build:native": "pnpm --filter @iracedeck/iracing-native build",
    "build:with-restart": "node scripts/build-with-restart.mjs",
    "build:stream-deck": "pnpm build:ts && pnpm restart:stream-deck",
    "restart:stream-deck": "streamdeck restart com.iracedeck.sd.core",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "lint": "eslint \"packages/*/src/**\"",
    "lint:fix": "eslint --fix \"packages/*/src/**\"",
    "format": "prettier --check \"**/*.ts\" \"**/*.json\"",
    "format:fix": "prettier --write \"**/*.ts\" \"**/*.json\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "precommit": "pnpm lint:fix && pnpm format:fix && pnpm install && pnpm clean && pnpm build",
    "start:stream-deck-app": "start /B \"\" \"C:\\Program Files\\Elgato\\StreamDeck\\StreamDeck.exe",
    "stop:stream-deck-app": "taskkill /IM StreamDeck.exe /F || exit 0",
    "link:stream-deck": "streamdeck link .\\packages\\stream-deck-plugin\\com.iracedeck.sd.core.sdPlugin",
    "unlink:stream-deck": "streamdeck unlink -d com.iracedeck.sd.core",
    "relink:stream-deck": "streamdeck unlink -d com.iracedeck.sd.core 2>NUL & streamdeck link .\\packages\\stream-deck-plugin\\com.iracedeck.sd.core.sdPlugin",
    "switch-test-env": "pnpm switch-test-env:stream-deck",
    "switch-test-env:stream-deck": "pnpm unlink:stream-deck -d && pnpm install && pnpm build && pnpm link:stream-deck",
    "telemetry-snapshot": "pnpm --filter @iracedeck/iracing-sdk telemetry-snapshot -- --include-session --output-dir=local",
    "watch:stream-deck": "pnpm --filter \"@iracedeck/stream-deck-plugin\" run watch",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run",
    "prepare": "husky || exit 0"
  },
  "devDependencies": {
    "@elgato/eslint-config": "0.3.2",
    "@elgato/prettier-config": "0.3.3",
    "@eslint/js": "9.39.4",
    "@stylistic/eslint-plugin": "5.10.0",
    "@svgdotjs/svg.js": "3.2.5",
    "@tsconfig/node22": "22.0.5",
    "@types/semver": "7.7.1",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "firebase-tools": "15.14.0",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "jsdom": "29.0.2",
    "lint-staged": "16.4.0",
    "node-gyp": "12.2.0",
    "prettier": "3.8.2",
    "release-it": "19.2.4",
    "semver": "7.7.4",
    "svgdom": "0.1.23",
    "svgpath": "2.6.0",
    "turbo": "2.9.6",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
