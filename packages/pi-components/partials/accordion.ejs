<!--
  Collapsible Component - A collapsible section with divider and arrow.
  Parameters:
    - title (String) — display label
    - content (HTML String)
    - open (Boolean, optional)
    - accordionId (String, optional) — persistence key; defaults to title.
      Must be unique per PI page when sections share the same title.
  Accordion open/closed state is persisted via Stream Deck global settings
  (_accordionState key) so it survives PI reloads when switching between keys.
-->
<details class="ird-collapsible" data-accordion-id="<%= (typeof accordionId !== 'undefined' && accordionId) ? accordionId : title %>" <%= (typeof open !== 'undefined' && open) ? 'open' : '' %>>
  <summary class="ird-collapsible-header">
    <span class="ird-collapsible-icon">&#9654;</span>
    <span class="ird-collapsible-title"><%= title %></span>
  </summary>
  <div class="ird-collapsible-content">
    <%- content %>
  </div>
</details>
