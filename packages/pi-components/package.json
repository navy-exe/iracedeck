    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@tsconfig/node22": "22.0.5",
    "@types/ejs": "3.1.5",
    "@types/node": "25.6.0",
    "ejs": "5.0.2",
    "rimraf": "6.1.3",
    "rollup": "4.60.1",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
