      "Tooltip": "Send an iRacing keyboard shortcut with preset defaults.",
      "PropertyInspectorPath": "ui/do-iracing-hotkey.html",
      "Controllers": ["Keypad"],
      "States": [
        {
          "Image": "imgs/actions/do-iracing-hotkey/key",
          "TitleAlignment": "middle",
          "FontSize": 8
        }
      ]
    }
  ],
  "Category": "iRaceDeck Hotkeys",
  "CategoryIcon": "imgs/plugin/category-icon",
