<!--
  Color Overrides Component

  Parameters:
    - slots: Array of slot names to show
    - defaults: Object mapping slot names to default hex colors
-->
<% const slotLabels = {
  backgroundColor: 'Background',
  textColor: 'Text',
  graphic1Color: 'Graphic 1',
  graphic2Color: 'Graphic 2'
};
var defaultBg = (defaults && defaults.backgroundColor) || '#2a2a2a';
var defaultText = (defaults && defaults.textColor) || '#ffffff';
var defaultG1 = (defaults && defaults.graphic1Color) || '#ffffff';
var defaultG2 = (defaults && defaults.graphic2Color) || '#ffffff';
%>
<%- include('accordion', {
  title: 'Color Overrides',
  open: false,
  content:
    '<sdpi-item label="Presets">' +
    '<div style="display:flex;gap:6px;flex-wrap:wrap;">' +
    '<button class="ird-override-preset" data-bg="' + defaultBg + '" data-text="' + defaultText + '" data-g1="' + defaultG1 + '" data-g2="' + defaultG2 + '"' +
      ' style="padding:4px 10px;border:1px solid #555;border-radius:4px;cursor:pointer;font-size:11px;background:#2a2a2a;color:#808080;">Default</button>' +
    '<button class="ird-override-preset" data-bg="#ffffff" data-text="#000000" data-g1="#000000" data-g2="#ffffff"' +
      ' style="padding:4px 10px;border:1px solid #555;border-radius:4px;cursor:pointer;font-size:11px;background:#ffffff;color:#000000;">White</button>' +
    '<button class="ird-override-preset" data-bg="#000000" data-text="#ffffff" data-g1="#ffffff" data-g2="#000000"' +
      ' style="padding:4px 10px;border:1px solid #555;border-radius:4px;cursor:pointer;font-size:11px;background:#000000;color:#ffffff;">Black</button>' +
    '<button class="ird-override-preset" data-bg="" data-text="" data-g1="" data-g2=""' +
      ' style="padding:4px 10px;border:1px solid #555;border-radius:4px;cursor:pointer;font-size:11px;background:#2a2a2a;color:#808080;">Global</button>' +
    '</div>' +
    '</sdpi-item>' +
    slots.map(function(slot) {
      var inputId = 'color-override-' + slot;
      return '<sdpi-item label="' + slotLabels[slot] + '">' +
        '<ird-color-picker id="' + inputId + '" setting="colorOverrides.' + slot + '"></ird-color-picker>' +
        '</sdpi-item>';
    }).join('\n')
}) %>
