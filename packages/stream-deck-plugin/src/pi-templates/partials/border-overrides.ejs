<!--
  Border Overrides Component

  Provides per-action border settings with Inherit/Yes/No dropdowns.
  "Inherit" (default) means the field is unset and falls through to global → icon default.
  For toggle actions, border color is driven by on/off/n/a state automatically.

  Parameters:
    - defaults: Object with per-action border defaults (e.g., { color: "#5a5a5a" })
-->
<% var defaultColor = (defaults && defaults.borderColor) || '#00aaff'; %>
<%- include('accordion', {
  title: 'Border',
  open: false,
  content:
    '<sdpi-item label="Show Border">' +
      '<sdpi-select id="ird-border-enabled" setting="borderOverrides.enabled" default="inherit">' +
        '<option value="inherit">Inherit</option>' +
        '<option value="true">Yes</option>' +
        '<option value="false">No</option>' +
      '</sdpi-select>' +
    '</sdpi-item>' +
    '<sdpi-item id="ird-border-width" class="hidden" label="Width">' +
      '<sdpi-range setting="borderOverrides.borderWidth" min="2" max="40" step="2" default="14" showlabels></sdpi-range>' +
    '</sdpi-item>' +
    '<sdpi-item id="ird-border-color" class="hidden" label="Color">' +
      '<sdpi-color setting="borderOverrides.borderColor" default="' + defaultColor + '"></sdpi-color>' +
    '</sdpi-item>' +
    '<sdpi-item id="ird-border-glow" class="hidden" label="Show Glow">' +
      '<sdpi-select id="ird-border-glow-select" setting="borderOverrides.glowEnabled" default="inherit">' +
        '<option value="inherit">Inherit</option>' +
        '<option value="true">Yes</option>' +
        '<option value="false">No</option>' +
      '</sdpi-select>' +
    '</sdpi-item>' +
    '<sdpi-item id="ird-border-glow-width" class="hidden" label="Glow Width">' +
      '<sdpi-range setting="borderOverrides.glowWidth" min="2" max="60" step="2" default="36" showlabels></sdpi-range>' +
    '</sdpi-item>'
}) %>

<script>
(function() {
  async function initBorderOverrides() {
    await customElements.whenDefined('sdpi-select');
    var borderSelect = document.getElementById('ird-border-enabled');
    var glowSelect = document.getElementById('ird-border-glow-select');
    if (!borderSelect) return;

    function isBorderEnabled() {
      return borderSelect.value === 'true';
    }

    function updateVisibility() {
      var showBorderSettings = isBorderEnabled();
      var items = ['ird-border-width', 'ird-border-color', 'ird-border-glow'];
      items.forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.classList.toggle('hidden', !showBorderSettings);
      });

      // Glow width visible only when border settings are shown AND glow is not "false"
      var glowVal = glowSelect ? glowSelect.value : 'inherit';
      var showGlowWidth = showBorderSettings && glowVal !== 'false';
      var glowWidthEl = document.getElementById('ird-border-glow-width');
      if (glowWidthEl) glowWidthEl.classList.toggle('hidden', !showGlowWidth);
    }

    updateVisibility();
    borderSelect.addEventListener('change', updateVisibility);
    borderSelect.addEventListener('input', updateVisibility);
    if (glowSelect) {
      glowSelect.addEventListener('change', updateVisibility);
      glowSelect.addEventListener('input', updateVisibility);
    }

    // Polling fallback (sdpi-select loads asynchronously)
    var lastBorder = borderSelect.value || 'inherit';
    var lastGlow = glowSelect ? (glowSelect.value || 'inherit') : 'inherit';
    setInterval(function() {
      var curBorder = borderSelect.value || 'inherit';
      var curGlow = glowSelect ? (glowSelect.value || 'inherit') : 'inherit';
      if (curBorder !== lastBorder || curGlow !== lastGlow) {
        lastBorder = curBorder;
        lastGlow = curGlow;
        updateVisibility();
      }
    }, 100);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBorderOverrides);
  } else {
    initBorderOverrides();
  }
})();
</script>
