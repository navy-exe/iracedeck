<meta charset="UTF-8" />
<script src="sdpi-components.js"></script>
<script src="pi-components.js"></script>
<style>
  .hidden {
    display: none !important;
  }

  /* Collapsible section styles */
  .ird-collapsible {
    margin-top: 12px;
  }

  .ird-collapsible-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 0 4px 0;
    cursor: pointer;
    user-select: none;
    list-style: none;
    border-top: 1px solid #3a3a3a;
  }

  .ird-collapsible-header::-webkit-details-marker {
    display: none;
  }

  .ird-collapsible-icon {
    font-size: 8px;
    color: #808080;
    transition: transform 0.15s ease;
    flex-shrink: 0;
  }

  .ird-collapsible[open] .ird-collapsible-icon {
    transform: rotate(90deg);
  }

  .ird-collapsible-title {
    font-family: "Segoe UI", Arial, Roboto, Helvetica, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: 9pt;
    font-weight: 600;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ird-collapsible-content {
    padding-top: 4px;
  }

  .ird-section-subtitle {
    font-family: "Segoe UI", Arial, Roboto, Helvetica, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: 9pt;
    color: #d0d0d0;
    margin: 8px 0 4px 14px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  /* Documentation link */
  .ird-docs-link {
    text-align: center;
    margin-top: 16px;
    padding-top: 8px;
    border-top: 1px solid #3a3a3a;
  }
  .ird-docs-link a {
    color: #4a90d9;
    font-family: "Segoe UI", Arial, Roboto, Helvetica, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: 9pt;
    text-decoration: none;
  }
  .ird-docs-link a:hover {
    color: #6fb0f0;
    text-decoration: underline;
  }
  .ird-docs-link a:focus-visible {
    color: #6fb0f0;
    text-decoration: underline;
    outline: 2px solid #4a90d9;
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Version footer */
  .ird-version {
    font-family: "Segoe UI", Arial, Roboto, Helvetica, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: 9pt;
    color: #888;
    text-align: center;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid #3a3a3a;
  }

  /* Key bindings section styles */
  .ird-section-heading {
    padding: 8px 0 4px 0;
    border-top: 1px solid #3a3a3a;
    font-family: "Segoe UI", Arial, Roboto, Helvetica, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: 9pt;
    font-weight: 600;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Section header (divides Action Settings from Global Settings) */
  .ird-section-header {
    margin: 20px 0 10px 0;
  }

  .ird-section-header:first-child {
    margin-top: 4px;
  }

  .ird-section-header-label {
    font-family: "Segoe UI", Arial, Roboto, Helvetica, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: 8pt;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #999;
  }

  .ird-section-header-rule {
    height: 1px;
    background: #555;
    margin-top: 6px;
  }
</style>
<script>
  // Accordion state persistence — store open/closed state in Stream Deck global
  // settings so it survives PI reloads (SD wipes the webview on each key selection).
  // Keyed by accordion title so state is shared across all action types.
  (function() {
    var SETTING_KEY = '_accordionState';
    var accordionState = {};
    var saveFn = null;

    function restoreAccordions() {
      document.querySelectorAll('.ird-collapsible[data-accordion-id]').forEach(function(el) {
        var id = el.getAttribute('data-accordion-id');
        if (id in accordionState) {
          if (accordionState[id]) {
            el.setAttribute('open', '');
          } else {
            el.removeAttribute('open');
          }
        }
      });
    }

    function saveState() {
      if (saveFn) saveFn(JSON.stringify(accordionState));
    }

    function initAccordions() {
      // Attach toggle listeners to each accordion
      document.querySelectorAll('.ird-collapsible[data-accordion-id]').forEach(function(el) {
        el.addEventListener('toggle', function() {
          var id = el.getAttribute('data-accordion-id');
          accordionState[id] = el.open;
          saveState();
        });
      });

      // Subscribe to the global setting via SDPIComponents
      if (window.SDPIComponents) {
        var hook = window.SDPIComponents.useGlobalSettings(
          SETTING_KEY,
          function(value) {
            if (value) {
              try { accordionState = JSON.parse(value); } catch (_) {}
            }
            restoreAccordions();
          },
          null
        );
        saveFn = hook[1];
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAccordions);
    } else {
      initAccordions();
    }
  })();

  // sdpi-textfield and sdpi-textarea don't reliably apply the default attribute
  // for new action instances. Wait for settings to load, then fill empty fields.
  setTimeout(() => {
    document.querySelectorAll("sdpi-textfield[default][setting], sdpi-textarea[default][setting]").forEach((el) => {
      if (!el.value) {
        el.value = el.getAttribute("default");
      }
    });
  }, 500);

  // Per-action override preset buttons
  document.addEventListener('click', function(ev) {
    var btn = ev.target.closest('.ird-override-preset');
    if (!btn) return;
    var mapping = {
      bg: 'color-override-backgroundColor',
      text: 'color-override-textColor',
      g1: 'color-override-graphic1Color',
      g2: 'color-override-graphic2Color'
    };
    ['bg', 'text', 'g1', 'g2'].forEach(function(key) {
      var color = btn.getAttribute('data-' + key);
      var el = document.getElementById(mapping[key]);
      if (el && color !== null) {
        el.value = color;
        el.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  });

  // Global color preset buttons — apply a full set of global colors at once
  document.addEventListener('click', function(ev) {
    var btn = ev.target.closest('.ird-color-preset');
    if (!btn) return;
    var mapping = {
      bg: 'global-color-bg',
      text: 'global-color-text',
      g1: 'global-color-g1',
      g2: 'global-color-g2'
    };
    ['bg', 'text', 'g1', 'g2'].forEach(function(key) {
      var color = btn.getAttribute('data-' + key);
      var el = document.getElementById(mapping[key]);
      if (el && color !== null) {
        el.value = color;
        el.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  });

  // Custom position visibility: per-action title position select
  (function() {
    function updateTitleCustomPosition(value) {
      var item = document.getElementById('title-custom-position-item');
      if (!item) return;
      if (value === 'custom') {
        item.classList.remove('hidden');
      } else {
        item.classList.add('hidden');
      }
    }

    async function initTitlePosition() {
      await customElements.whenDefined('sdpi-select');
      var select = document.getElementById('title-override-position');
      if (!select) return;
      updateTitleCustomPosition(select.value || 'inherit');
      select.addEventListener('change', function(e) { updateTitleCustomPosition(e.target.value); });
      select.addEventListener('input', function(e) { updateTitleCustomPosition(e.target.value); });
      var lastVal = select.value || 'inherit';
      setInterval(function() {
        var cur = select.value;
        if (cur && cur !== lastVal) {
          lastVal = cur;
          updateTitleCustomPosition(cur);
        }
      }, 100);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTitlePosition);
    } else {
      initTitlePosition();
    }
  })();

  // Custom position visibility: global title position select
  (function() {
    function updateGlobalTitleCustomPosition(value) {
      var item = document.getElementById('global-title-custom-position-item');
      if (!item) return;
      if (value === 'custom') {
        item.classList.remove('hidden');
      } else {
        item.classList.add('hidden');
      }
    }

    async function initGlobalTitlePosition() {
      await customElements.whenDefined('sdpi-select');
      var select = document.getElementById('global-title-position');
      if (!select) return;
      updateGlobalTitleCustomPosition(select.value || 'default');
      select.addEventListener('change', function(e) { updateGlobalTitleCustomPosition(e.target.value); });
      select.addEventListener('input', function(e) { updateGlobalTitleCustomPosition(e.target.value); });
      var lastVal = select.value || 'default';
      setInterval(function() {
        var cur = select.value;
        if (cur && cur !== lastVal) {
          lastVal = cur;
          updateGlobalTitleCustomPosition(cur);
        }
      }, 100);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initGlobalTitlePosition);
    } else {
      initGlobalTitlePosition();
    }
  })();

  // Font Size checkbox gate: sdpi-checkbox (persists via setting attribute) + ird-range-input.
  // When unchecked: hide range, clear fontSize setting.
  // When checked: show range, sdpi persists fontSize normally.
  (function() {
    async function initFontSizeToggle() {
      await customElements.whenDefined('sdpi-checkbox');
      var toggle = document.getElementById('title-override-fontSize-toggle');
      var item = document.getElementById('title-fontSize-item');
      var range = document.getElementById('title-override-fontSize');
      if (!toggle || !item || !range) return;

      function isChecked() {
        return toggle.checked === true || toggle.value === true || toggle.value === 'true';
      }

      function showControls(show) {
        if (show) {
          item.classList.remove('hidden');
          if (!range.value || range.value === '') {
            range.value = '9';
            range.dispatchEvent(new Event('change', { bubbles: true }));
          }
        } else {
          item.classList.add('hidden');
          range.value = '';
          range.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }

      toggle.addEventListener('change', function() {
        showControls(isChecked());
      });

      // Initial state check
      showControls(isChecked());

      // Polling fallback for checkbox state (sdpi-checkbox loads asynchronously)
      var lastChecked = isChecked();
      setInterval(function() {
        var cur = isChecked();
        if (cur !== lastChecked) {
          lastChecked = cur;
          showControls(cur);
        }
      }, 100);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFontSizeToggle);
    } else {
      initFontSizeToggle();
    }
  })();

  // Global Font Size "Use icon default" checkbox gate
  // When checked: hide range (fontSize = "default", defers to icon).
  // When unchecked: show range, use the global fontSize value.
  (function() {
    async function initGlobalFontSizeToggle() {
      await customElements.whenDefined('sdpi-checkbox');
      var toggle = document.getElementById('global-title-fontSize-default');
      var item = document.getElementById('global-title-fontSize-item');
      if (!toggle || !item) return;

      function isChecked() {
        return toggle.checked === true || toggle.value === true || toggle.value === 'true';
      }

      function showRange(show) {
        if (show) {
          item.classList.remove('hidden');
        } else {
          item.classList.add('hidden');
        }
      }

      toggle.addEventListener('change', function() { showRange(!isChecked()); });
      toggle.addEventListener('input', function() { showRange(!isChecked()); });

      // Initial state check
      showRange(!isChecked());

      var lastChecked = isChecked();
      setInterval(function() {
        var cur = isChecked();
        if (cur !== lastChecked) {
          lastChecked = cur;
          showRange(!cur);
        }
      }, 100);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initGlobalFontSizeToggle);
    } else {
      initGlobalFontSizeToggle();
    }
  })();

  // Global title defaults Reset button
  document.addEventListener('click', function(ev) {
    var btn = ev.target.closest('.ird-title-global-reset');
    if (!btn) return;

    var defaults = {
      'titleShowTitle': 'true',
      'titleShowGraphics': 'true',
      'titleBold': 'default',
      'titleFontSizeDefault': 'true',
      'titleFontSize': '9',
      'titlePosition': 'default',
      'titleCustomPosition': '0'
    };

    Object.entries(defaults).forEach(function([setting, value]) {
      var el = document.querySelector('[setting="' + setting + '"]');
      if (el) {
        el.value = value;
        el.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });

  });

  // Note: titleOverrides.titleText uses sdpi-textarea with setting attribute.
  // Persistence is handled automatically by sdpi-components.

  // Global Border Defaults — show/hide sub-settings based on Show Border and Show Glow
  (function() {
    async function initGlobalBorderToggle() {
      await customElements.whenDefined('sdpi-select');
      var borderSelect = document.getElementById('global-border-enabled');
      var glowSelect = document.getElementById('global-border-glow-enabled');
      if (!borderSelect) return;

      function updateGlobalBorderVisibility() {
        var show = borderSelect.value === 'true';
        ['global-border-width-item', 'global-border-color-item', 'global-border-glow-item'].forEach(function(id) {
          var el = document.getElementById(id);
          if (el) el.classList.toggle('hidden', !show);
        });
        var glowVal = glowSelect ? glowSelect.value : 'default';
        var showGlowWidth = show && glowVal === 'true';
        var glowWidthEl = document.getElementById('global-border-glow-width-item');
        if (glowWidthEl) glowWidthEl.classList.toggle('hidden', !showGlowWidth);
      }

      updateGlobalBorderVisibility();
      borderSelect.addEventListener('change', updateGlobalBorderVisibility);
      borderSelect.addEventListener('input', updateGlobalBorderVisibility);
      if (glowSelect) {
        glowSelect.addEventListener('change', updateGlobalBorderVisibility);
        glowSelect.addEventListener('input', updateGlobalBorderVisibility);
      }

      var lastBorder = borderSelect.value || 'default';
      var lastGlow = glowSelect ? (glowSelect.value || 'default') : 'default';
      setInterval(function() {
        var curBorder = borderSelect.value || 'default';
        var curGlow = glowSelect ? (glowSelect.value || 'default') : 'default';
        if (curBorder !== lastBorder || curGlow !== lastGlow) {
          lastBorder = curBorder;
          lastGlow = curGlow;
          updateGlobalBorderVisibility();
        }
      }, 100);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initGlobalBorderToggle);
    } else {
      initGlobalBorderToggle();
    }
  })();
</script>
