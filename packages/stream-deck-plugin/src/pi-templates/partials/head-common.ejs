<meta charset="UTF-8" />
<script src="sdpi-components.js"></script>
<script src="pi-components.js"></script>
<style>
  .hidden {
    display: none !important;
  }

  /* Collapsible section styles */
  .ird-collapsible {
    margin-top: 12px;
  }

  .ird-collapsible-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 0 4px 0;
    cursor: pointer;
    user-select: none;
    list-style: none;
    border-top: 1px solid #3a3a3a;
  }

  .ird-collapsible-header::-webkit-details-marker {
    display: none;
  }

  .ird-collapsible-icon {
    font-size: 8px;
    color: #808080;
    transition: transform 0.15s ease;
    flex-shrink: 0;
  }

  .ird-collapsible[open] .ird-collapsible-icon {
    transform: rotate(90deg);
  }

  .ird-collapsible-title {
    font-family: "Segoe UI", Arial, Roboto, Helvetica, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: 9pt;
    font-weight: 600;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ird-collapsible-content {
    padding-top: 4px;
  }

  .ird-section-subtitle {
    font-family: "Segoe UI", Arial, Roboto, Helvetica, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: 9pt;
    color: #d0d0d0;
    margin: 8px 0 4px 14px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  /* Documentation link */
  .ird-docs-link {
    text-align: center;
    margin-top: 16px;
    padding-top: 8px;
    border-top: 1px solid #3a3a3a;
  }
  .ird-docs-link a {
    color: #4a90d9;
    font-family: "Segoe UI", Arial, Roboto, Helvetica, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: 9pt;
    text-decoration: none;
  }
  .ird-docs-link a:hover {
    color: #6fb0f0;
    text-decoration: underline;
  }
  .ird-docs-link a:focus-visible {
    color: #6fb0f0;
    text-decoration: underline;
    outline: 2px solid #4a90d9;
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Version footer */
  .ird-version {
    font-family: "Segoe UI", Arial, Roboto, Helvetica, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: 9pt;
    color: #888;
    text-align: center;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid #3a3a3a;
  }

  /* Key bindings section styles */
  .ird-section-heading {
    padding: 8px 0 4px 0;
    border-top: 1px solid #3a3a3a;
    font-family: "Segoe UI", Arial, Roboto, Helvetica, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: 9pt;
    font-weight: 600;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
</style>
<script>
  // sdpi-textfield and sdpi-textarea don't reliably apply the default attribute
  // for new action instances. Wait for settings to load, then fill empty fields.
  setTimeout(() => {
    document.querySelectorAll("sdpi-textfield[default][setting], sdpi-textarea[default][setting]").forEach((el) => {
      if (!el.value) {
        el.value = el.getAttribute("default");
      }
    });
  }, 500);

  // Per-action override preset buttons
  document.addEventListener('click', function(ev) {
    var btn = ev.target.closest('.ird-override-preset');
    if (!btn) return;
    var mapping = {
      bg: 'color-override-backgroundColor',
      text: 'color-override-textColor',
      g1: 'color-override-graphic1Color',
      g2: 'color-override-graphic2Color'
    };
    ['bg', 'text', 'g1', 'g2'].forEach(function(key) {
      var color = btn.getAttribute('data-' + key);
      var el = document.getElementById(mapping[key]);
      if (el && color) {
        el.value = color;
        el.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  });

  // Global color preset buttons — apply a full set of global colors at once
  document.addEventListener('click', function(ev) {
    var btn = ev.target.closest('.ird-color-preset');
    if (!btn) return;
    var mapping = {
      bg: 'global-color-bg',
      text: 'global-color-text',
      g1: 'global-color-g1',
      g2: 'global-color-g2'
    };
    ['bg', 'text', 'g1', 'g2'].forEach(function(key) {
      var color = btn.getAttribute('data-' + key);
      var el = document.getElementById(mapping[key]);
      if (el && color) {
        el.value = color;
        el.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  });

  // Color picker reset buttons — event delegation for all .ird-color-reset links
  // Per-action: resets to icon default color. Global: resets to #000001 (treated as "not set").
  document.addEventListener('click', function(ev) {
    var link = ev.target.closest('.ird-color-reset');
    if (!link) return;
    ev.preventDefault();
    var inputId = link.getAttribute('data-input');
    var defaultColor = link.getAttribute('data-default') || '#000000';
    var colorEl = document.getElementById(inputId);
    if (colorEl) {
      colorEl.value = defaultColor;
      colorEl.dispatchEvent(new Event('change', { bubbles: true }));
    }
  });

  // Custom position visibility: per-action title position select
  (function() {
    function updateTitleCustomPosition(value) {
      var item = document.getElementById('title-custom-position-item');
      if (!item) return;
      if (value === 'custom') {
        item.classList.remove('hidden');
      } else {
        item.classList.add('hidden');
      }
    }

    async function initTitlePosition() {
      await customElements.whenDefined('sdpi-select');
      var select = document.getElementById('title-override-position');
      if (!select) return;
      updateTitleCustomPosition(select.value || 'inherit');
      select.addEventListener('change', function(e) { updateTitleCustomPosition(e.target.value); });
      select.addEventListener('input', function(e) { updateTitleCustomPosition(e.target.value); });
      var lastVal = select.value || 'inherit';
      setInterval(function() {
        var cur = select.value;
        if (cur && cur !== lastVal) {
          lastVal = cur;
          updateTitleCustomPosition(cur);
        }
      }, 100);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTitlePosition);
    } else {
      initTitlePosition();
    }
  })();

  // Custom position visibility: global title position select
  (function() {
    function updateGlobalTitleCustomPosition(value) {
      var item = document.getElementById('global-title-custom-position-item');
      if (!item) return;
      if (value === 'custom') {
        item.classList.remove('hidden');
      } else {
        item.classList.add('hidden');
      }
    }

    async function initGlobalTitlePosition() {
      await customElements.whenDefined('sdpi-select');
      var select = document.getElementById('global-title-position');
      if (!select) return;
      updateGlobalTitleCustomPosition(select.value || 'bottom');
      select.addEventListener('change', function(e) { updateGlobalTitleCustomPosition(e.target.value); });
      select.addEventListener('input', function(e) { updateGlobalTitleCustomPosition(e.target.value); });
      var lastVal = select.value || 'bottom';
      setInterval(function() {
        var cur = select.value;
        if (cur && cur !== lastVal) {
          lastVal = cur;
          updateGlobalTitleCustomPosition(cur);
        }
      }, 100);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initGlobalTitlePosition);
    } else {
      initGlobalTitlePosition();
    }
  })();

  // Bidirectional sync between sdpi-range and number input
  function syncRangeAndInput(rangeId, inputId) {
    var range = document.getElementById(rangeId);
    var input = document.getElementById(inputId);
    if (!range || !input) return;

    // Range → Input
    range.addEventListener('input', function() { input.value = range.value; });
    range.addEventListener('change', function() { input.value = range.value; });

    // Input → Range (also trigger change for sdpi persistence)
    input.addEventListener('change', function() {
      var val = Math.min(Math.max(Number(input.value), Number(input.min)), Number(input.max));
      input.value = val;
      range.value = val;
      range.dispatchEvent(new Event('change', { bubbles: true }));
    });

    // Initialize input from range on load
    if (range.value) input.value = range.value;
  }

  (function() {
    function initRangeSyncs() {
      syncRangeAndInput('title-override-customPosition', 'title-override-customPosition-input');
      syncRangeAndInput('global-title-fontSize', 'global-title-fontSize-input');
      syncRangeAndInput('global-title-customPosition', 'global-title-customPosition-input');
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initRangeSyncs);
    } else {
      initRangeSyncs();
    }
  })();

  // Font Size checkbox gate: sdpi-checkbox (persists via setting attribute) + sdpi-range.
  // When unchecked: hide range, clear fontSize setting.
  // When checked: show range, sdpi persists fontSize normally.
  (function() {
    async function initFontSizeToggle() {
      await customElements.whenDefined('sdpi-checkbox');
      var toggle = document.getElementById('title-override-fontSize-toggle');
      var item = document.getElementById('title-fontSize-item');
      var range = document.getElementById('title-override-fontSize');
      var input = document.getElementById('title-override-fontSize-input');
      if (!toggle || !item || !range || !input) return;

      function isChecked() {
        // sdpi-checkbox may use .checked or .value
        return toggle.checked === true || toggle.value === true || toggle.value === 'true';
      }

      function showControls(show) {
        if (show) {
          item.classList.remove('hidden');
          // Set default value if range is empty
          if (!range.value || range.value === '') {
            range.value = '18';
            input.value = '18';
            range.dispatchEvent(new Event('change', { bubbles: true }));
          }
        } else {
          item.classList.add('hidden');
          // Clear fontSize so it inherits
          range.value = '';
          range.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }

      // Listen for checkbox changes
      toggle.addEventListener('change', function() {
        showControls(isChecked());
      });

      // Sync range → input
      range.addEventListener('input', function() { input.value = range.value; });
      range.addEventListener('change', function() { if (range.value) input.value = range.value; });

      // Input → range
      input.addEventListener('change', function() {
        var val = Math.min(Math.max(Number(input.value), 5), 100);
        input.value = val;
        range.value = val;
        range.dispatchEvent(new Event('change', { bubbles: true }));
      });

      // Sync input: poll the range value since sdpi-range loads asynchronously
      var settingsHaveLoaded = false;
      document.addEventListener('settingsLoaded', function() {
        settingsHaveLoaded = true;
        showControls(isChecked());
      });

      var syncInterval = setInterval(function() {
        if (range.value && range.value !== '' && input.value !== range.value) {
          input.value = range.value;
        }
        // Only stop polling after settings have loaded AND values are synced
        if (settingsHaveLoaded && range.value && input.value === range.value) {
          clearInterval(syncInterval);
        }
      }, 200);

      // Polling fallback for checkbox state
      var lastChecked = isChecked();
      setInterval(function() {
        var cur = isChecked();
        if (cur !== lastChecked) {
          lastChecked = cur;
          showControls(cur);
        }
      }, 100);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFontSizeToggle);
    } else {
      initFontSizeToggle();
    }
  })();

  // Global title defaults Reset button
  document.addEventListener('click', function(ev) {
    var btn = ev.target.closest('.ird-title-global-reset');
    if (!btn) return;

    var defaults = {
      'titleShowTitle': 'true',
      'titleShowGraphics': 'true',
      'titleBold': 'true',
      'titleFontSize': '18',
      'titlePosition': 'bottom',
      'titleCustomPosition': '0'
    };

    Object.entries(defaults).forEach(function([setting, value]) {
      var el = document.querySelector('[setting="' + setting + '"]');
      if (el) {
        el.value = value;
        el.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });

    // Also sync the number inputs
    var fontInput = document.getElementById('global-title-fontSize-input');
    if (fontInput) fontInput.value = '18';
    var posInput = document.getElementById('global-title-customPosition-input');
    if (posInput) posInput.value = '0';
  });

  // Note: titleOverrides.titleText uses sdpi-textarea with setting attribute.
  // Persistence is handled automatically by sdpi-components.
</script>
