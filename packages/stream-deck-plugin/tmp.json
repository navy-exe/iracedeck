{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./com.iracedeck.sd.sdPlugin/bin",
    "rootDir": "./src",
    "customConditions": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "com.iracedeck.sd.sdPlugin"]
}
